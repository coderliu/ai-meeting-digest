<% content_for :title, "Transcript ##{@transcript.id}" %>

<div class="w-full max-w-4xl mx-auto">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center mb-8">
    <h1 class="font-bold text-4xl">会议纪要 #<%= @transcript.uuid %></h1>
    <% unless @share_mode %>
      <div class="flex items-center space-x-3">
        <button data-controller="share"
                data-share-url-value="<%= share_transcript_url(@transcript.uuid) %>"
                data-action="click->share#share"
                class="inline-flex items-center px-3.5 py-2.5 bg-green-600 hover:bg-green-500 text-white font-medium rounded-md transition-colors duration-200">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.367 2.684 3 3 0 00-5.367-2.684z"></path>
          </svg>
          分享
        </button>
        <%= link_to "编辑", edit_transcript_path(id: @transcript.uuid), class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white block font-medium" %>
        <%= link_to "返回列表", transcripts_path, class: "rounded-md px-3.5 py-2.5 bg-gray-600 hover:bg-gray-500 text-white block font-medium" %>
      </div>
    <% end %>
  </div>

  <!-- 状态信息 -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-semibold text-gray-900">状态信息</h2>
      <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium
        <%= case @transcript.status
            when 'initial'
              'bg-yellow-100 text-yellow-800'
            when 'done'
              'bg-green-100 text-green-800'
            when 'interrupted'
              'bg-red-100 text-red-800'
            else
              'bg-gray-100 text-gray-800'
            end %>">
        <%= case @transcript.status
            when 'initial'
              '处理中'
            when 'done'
              '已完成'
            when 'interrupted'
              '已中断'
            else
              @transcript.status
            end %>
      </span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm text-gray-600">
      <div>
        <span class="font-medium">创建时间：</span>
        <%= @transcript.created_at.strftime("%Y年%m月%d日 %H:%M:%S") %>
      </div>
      <div>
        <span class="font-medium">更新时间：</span>
        <%= @transcript.updated_at.strftime("%Y年%m月%d日 %H:%M:%S") %>
      </div>
      <div>
        <span class="font-medium">UUID：</span>
        <code class="bg-gray-100 px-2 py-1 rounded text-xs"><%= @transcript.uuid %></code>
      </div>
    </div>
  </div>

  <!-- 输入内容 -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-8">
    <h2 class="text-xl font-semibold text-gray-900 mb-4">原始会议纪要</h2>
    <div class="bg-gray-50 rounded-lg p-4">
      <pre class="whitespace-pre-wrap text-sm text-gray-700 font-mono"><%= @transcript.input %></pre>
    </div>
  </div>

  <!-- AI 输出内容 -->
  <% if @transcript.output.present? %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">AI 生成的摘要</h2>
      <div class="prose prose-gray max-w-none">
        <%= render_markdown(@transcript.output) %>
      </div>
    </div>
  <% else %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">AI 生成的摘要</h2>
      <div class="text-center py-8">
        <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
          </svg>
        </div>
        <p class="text-gray-500">暂无 AI 生成内容</p>
      </div>
    </div>
  <% end %>
</div>
