<div id="<%= dom_id transcript %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Input:</strong>
    <%= transcript.input %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Output:</strong>
    <%= transcript.output %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Uuid:</strong>
    <%= transcript.uuid %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Status:</strong>
    <%= transcript.status %>
  </div>
</div>
